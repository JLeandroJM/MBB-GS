{
  "_comentario_general": "Identificacion del experimento y datos de entrada",

  "nombre_experimento": "testeo_l2",
  "base": "chebyshev",
  "clip": "baileGANGMANG_clips",

  "_comentario_video": "Configuracion de extraccion/carga de frames",

  "video_mp4": null,
  "n_frames_extraer": null,
  "fps_extraccion": null,
  "resolucion_extraccion": [256, 256],
  "forzar_extraccion": false,
  "max_frames": 100,

  "_comentario_dispositivo": "Device y semilla",

  "device": "cuda",
  "seed": 42,

  "_comentario_modelo": "Configuracion principal del modelo de gaussianas",

  "n_gaussianas_inicial": 20000,
  "inicializar_color_desde_frame0": true,
  "escala_inicial_px": 2,

  "_comentario_grados": "Grados temporales por parametro",

  "grados": {
    "mu": 36,
    "opacity": 22,
    "color": 22,
    "scale": 8,
    "theta": 4,
    "depth": 4
  },

  "_comentario_lrs": "Learning rates por tipo de parametro y coeficientes temporales",

  "lrs": {
    "mu_a0": 0.001,
    "mu_high": 0.005,
    "opacity_a0": 0.05,
    "opacity_high": 0.05,
    "color_a0": 0.01,
    "color_high": 0.01,
    "scale_a0": 0.005,
    "scale_high": 0.005,
    "theta_a0": 0.005,
    "theta_high": 0.0025,
    "depth_a0": 0.001,
    "depth_high": 0.0001
  },

  "_comentario_entrenamiento": "Configuracion del loop de entrenamiento",

  "n_epochs": 100,
  "checkpoint_cada_n_epochs": 200,
  "sub_batch_frames": 4,

  "_comentario_muestreo_temporal": "Muestreo por bloques temporales. Con 588 frames y bloque 28 hay 21 bloques. Con 6 muestras por bloque se usan 126 frames por epoch",

  "usar_muestreo_temporal_por_bloques": false,
  "fps_grupo_temporal": 0,
  "frames_por_grupo_temporal": 18,
  "frames_por_epoch": null,

  "_comentario_loss": "Loss principal. usar_loss_cuda=true requiere lambda_dssim=0",

  "lambda_dssim": 0,
  "usar_loss_cuda": true,

  "_comentario_smoothness": "Regularizacion temporal de coeficientes altos",

  "beta_smoothness": 1e-6,

  "pesos_smoothness": {
    "mu": 0.0,
    "opacity": 0.0,
    "color": 0.0,
    "scale": 0.0,
    "theta": 1.0,
    "depth": 2.0
  },

  "_comentario_cuda": "Configuracion del rasterizador CUDA",

  "usar_cuda_conic": false,
  "usar_cuda_tiled": true,
  "cuda_tile_size": 16,
  "cuda_k_sigma": 4,

  "_comentario_scheduler": "Scheduler lento para reducir LR si la loss se estanca",

  "usar_scheduler_lento": true,
  "scheduler_lento_window": 300,
  "scheduler_lento_min_delta": 0.0001,
  "scheduler_lento_factor": 0.3,
  "scheduler_lento_min_lr": 0.000001,
  "scheduler_lento_cooldown": 40,

  "_comentario_pruning": "Pruning post-training por contribucion maxima de opacidad",

  "umbral_pruning_post": 0.02,
  "ejecutar_pruning_post": true,

  "_comentario_metricas": "Metricas de calidad final",

  "calcular_metricas": true,
  "usar_ssim": true,
  "usar_lpips": true,

  "_comentario_compresion": "Metricas de compresion y comparacion con AVIF",

  "calcular_compresion": false,
  "calidades_avif": [80, 95],

  "_comentario_salidas_entrenamiento": "Checkpoints y verificaciones durante entrenamiento",

  "guardar_checkpoints_intermedios": true,
  "guardar_verificacion_visual": true,

  "_comentario_salidas_finales": "Archivos finales generados despues del entrenamiento",

  "guardar_visualizaciones": true,
  "guardar_gif": false,
  "guardar_frames_rasterizados": true
}